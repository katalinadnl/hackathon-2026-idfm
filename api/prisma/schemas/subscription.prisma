enum SubscriptionStatus {
  active
  expired
  cancelled
  pending_cancellation
}

model Subscription {
  id        Int    @id @default(autoincrement())
  reference String @unique @default(cuid())

  beneficiaryId    Int
  subscriptionType String
  startDate        DateTime
  endDate          DateTime
  status           SubscriptionStatus @default(active)

  // Renseignés uniquement lors d'une résiliation, conformément aux CGU IDFM :
  // pas de préavis pour la demande, mais le mois en cours reste dû et la
  // résiliation ne prend effet qu'au 1er jour du mois suivant.
  cancelledAt             DateTime? // date à laquelle la demande a été faite
  cancellationEffectiveAt DateTime? // date à laquelle status passera à "cancelled"
  cancelledById           Int? // qui a fait la demande (titulaire ou référant)
  bankInfoId              Int
  transportProductId      Int?

  beneficiary      Beneficiary       @relation("SubscriptionHolder", fields: [beneficiaryId], references: [id])
  cancelledBy      Account?          @relation("SubscriptionCancelledBy", fields: [cancelledById], references: [id])
  bankInfo         BankInfo          @relation("BankInfo", fields: [bankInfoId], references: [id])
  transportProduct TransportProduct? @relation(fields: [transportProductId], references: [id])

  paymentMode   PaymentMode @default(SEPA_MONTHLY)
  annualAmount  Float       @default(0)
  monthlyAmount Float?
  payments      Payment[]
  passes        Pass[]
}

enum PaymentMode {
  CARD_ONCE
  SEPA_ONCE
  SEPA_MONTHLY
}

enum PaymentStatus {
  succeeded
  failed
  pending
}

model Payment {
  id             Int           @id @default(autoincrement())
  subscriptionId Int
  amount         Float
  paidAt         DateTime      @default(now())
  method         PaymentMode
  status         PaymentStatus @default(succeeded)

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@unique([subscriptionId, paidAt, amount])
}

enum VerificationSource {
  MANUAL_DOCUMENT
  STATE_API
  DECLARATIVE
}

model StatusVerification {
  id            Int                @id @default(autoincrement())
  beneficiaryId Int
  status        BeneficiaryStatus
  source        VerificationSource
  verified      Boolean            @default(false)

  documentUrl    String?
  expirationDate DateTime?

  apiName      String?
  apiReference String?
  apiQueriedAt DateTime?

  validFrom         DateTime?
  validUntil        DateTime?
  createdAt         DateTime         @default(now())
  tariffReductionId Int?
  tariffReduction   TariffReduction? @relation(fields: [tariffReductionId], references: [id])

  beneficiary Beneficiary @relation(fields: [beneficiaryId], references: [id])
}

// Synchronisé depuis le jeu de données ouvert IDFM "titres-et-tarifs"
// (https://data.iledefrance-mobilites.fr/explore/dataset/titres-et-tarifs/).
model TransportProduct {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  indication  String?
  period      String?

  priceLabel String
  priceCents Int?

  sellingArguments String[]
  subscriptionTag  String?
  portalUrl        String?
  rechargeUrl      String?
  imageUrl         String?

  isAnnualPlan Boolean  @default(false)
  syncedAt     DateTime @default(now()) @updatedAt

  subscriptions Subscription[]
  reductions    TariffReduction[]
}

model TariffReduction {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  indication  String?

  reductionPercent Int?
  isFree           Boolean  @default(false)
  sellingArguments String[]
  syncedAt         DateTime @default(now()) @updatedAt

  baseProductId Int?
  baseProduct   TransportProduct? @relation(fields: [baseProductId], references: [id])

  statusVerifications StatusVerification[]
}
