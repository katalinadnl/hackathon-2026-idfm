model Subscription {
  id               Int      @id @default(autoincrement())
  beneficiaryId    Int
  referrerId       Int?
  payerId          Int?
  navigoNumber     String   @unique
  subscriptionType String
  startDate        DateTime
  endDate          DateTime
  status           String   @default("active")

  beneficiary Beneficiary @relation("SubscriptionHolder", fields: [beneficiaryId], references: [id])
  referrer    Account?    @relation("SubscriptionReferrer", fields: [referrerId], references: [id])
  payer       Account?    @relation("SubscriptionPayer", fields: [payerId], references: [id])

  payments Payment[]
}

model Payment {
  id             Int      @id @default(autoincrement())
  subscriptionId Int
  amount         Float
  paidAt         DateTime @default(now())
  method         String
  status         String   @default("succeeded")

  subscription Subscription @relation(fields: [subscriptionId], references: [id])
}
