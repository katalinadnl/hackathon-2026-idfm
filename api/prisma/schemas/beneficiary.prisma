enum AddressType {
  home
  delivery
  billing
}

model Address {
  id            Int         @id @default(autoincrement())
  beneficiaryId Int
  type          AddressType @default(home)
  isDefault     Boolean     @default(false)

  line1      String
  line2      String?
  city       String
  postalCode String
  country    String  @default("FR")

  createdAt DateTime @default(now())

  beneficiary Beneficiary @relation(fields: [beneficiaryId], references: [id])
  deliveries  Delivery[]
}

enum BeneficiaryStatus {
  ACTIVE
  STUDENT
  SENIOR
  UNEMPLOYED
  DISABLED
  MINOR
}

model Department {
  id     Int    @id @default(autoincrement())
  code   String @unique
  name   String
  region String

  residents       Beneficiary[] @relation("ResidenceDepartment")
  workersStudents Beneficiary[] @relation("WorkStudyDepartment")
}

model Beneficiary {
  id                   Int               @id @default(autoincrement())
  firstName            String
  lastName             String
  birthDate            DateTime
  socialSecurityNumber String?           @unique
  status               BeneficiaryStatus @default(ACTIVE)
  // Titulaire : 1 compte ne peut posséder qu'1 seul bénéficiaire en propre
  // (le @unique porte ici, côté FK — c'est lui qui plafonne à 1, pas un
  // @unique côté Account). Optionnel : un bénéficiaire peut n'avoir aucun
  // compte titulaire (ex: mineur géré uniquement via le référent).
  accountTitulaireId   Int?              @unique
  accountTitulaire     Account?          @relation("AccountTitulaire", fields: [accountTitulaireId], references: [id])

  // Référent : indépendant du titulaire. Optionnel — un bénéficiaire peut
  // n'avoir aucun référent (cas du titulaire qui gère lui-même), ou être
  // référé par un compte alors qu'il a (ou pas) son propre compte titulaire
  // par ailleurs. Pas de @unique ici : un compte référent peut gérer une
  // infinité de bénéficiaires référés.
  accountReferantId Int?
  accountReferant   Account? @relation("AccountReferant", fields: [accountReferantId], references: [id])

  residenceDepartmentId Int
  workStudyDepartmentId Int?

  residenceDepartment Department  @relation("ResidenceDepartment", fields: [residenceDepartmentId], references: [id])
  workStudyDepartment Department? @relation("WorkStudyDepartment", fields: [workStudyDepartmentId], references: [id])

  statusVerifications StatusVerification[]
  subscriptions       Subscription[]       @relation("SubscriptionHolder")

  addresses Address[]
}
