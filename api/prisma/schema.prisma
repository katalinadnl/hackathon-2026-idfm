// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum BeneficiaryStatus {
  ACTIVE
  STUDENT
  SENIOR
  UNEMPLOYED
  DISABLED
  MINOR
}

enum VerificationSource {
  MANUAL_DOCUMENT
  STATE_API
  DECLARATIVE
}

model Department {
  id     Int    @id @default(autoincrement())
  code   String @unique
  name   String
  region String

  residents       Beneficiary[] @relation("ResidenceDepartment")
  workersStudents Beneficiary[] @relation("WorkStudyDepartment")
}

model Beneficiary {
  id                   Int               @id @default(autoincrement())
  firstName            String
  lastName             String
  email                String            @unique
  phone                String?
  birthDate            DateTime
  socialSecurityNumber String?           @unique
  status               BeneficiaryStatus @default(ACTIVE)

  residenceDepartmentId Int
  workStudyDepartmentId Int?

  residenceDepartment Department  @relation("ResidenceDepartment", fields: [residenceDepartmentId], references: [id])
  workStudyDepartment Department? @relation("WorkStudyDepartment", fields: [workStudyDepartmentId], references: [id])

  statusVerifications StatusVerification[]
  account             Account?
  subscriptions       Subscription[]       @relation("SubscriptionHolder")
}

model StatusVerification {
  id            Int                @id @default(autoincrement())
  beneficiaryId Int
  status        BeneficiaryStatus
  source        VerificationSource
  verified      Boolean            @default(false)

  documentUrl    String?
  expirationDate DateTime?

  apiName      String?
  apiReference String?
  apiQueriedAt DateTime?

  validFrom  DateTime?
  validUntil DateTime?
  createdAt  DateTime  @default(now())

  beneficiary Beneficiary @relation(fields: [beneficiaryId], references: [id])
}

enum PaymentMode {
  CARD_ONCE
  SEPA_ONCE
  SEPA_MONTHLY
}

enum AccountRole {
  client
  admin
}

model Account {
  id            Int         @id @default(autoincrement())
  email         String      @unique
  passwordHash  String
  accountNumber String      @unique
  createdAt     DateTime    @default(now())
  role          AccountRole @default(client)

  beneficiaryId Int?         @unique
  beneficiary   Beneficiary? @relation(fields: [beneficiaryId], references: [id])

  // Stripe linkage — set for accounts that pay (payers become customers).
  stripeCustomerId        String? @unique
  stripePaymentMethodId   String? // default SEPA payment method
  stripeMandateId         String? // mandate generated for that payment method
  stripePreviousMandateId String? // last revoked mandate (after a RIB change)

  // 2FA via email OTP
  twoFactorCode      String?
  twoFactorExpiresAt DateTime?

  // Reset mot de passe
  resetPasswordToken     String?   @unique
  resetPasswordExpiresAt DateTime?

  referredSubscriptions Subscription[] @relation("SubscriptionReferrer")
  paidSubscriptions     Subscription[] @relation("SubscriptionPayer")
}

model Subscription {
  id               Int         @id @default(autoincrement())
  beneficiaryId    Int
  referrerId       Int?
  payerId          Int?
  navigoNumber     String      @unique
  subscriptionType String
  startDate        DateTime
  endDate          DateTime
  status           String      @default("active")
  paymentMode      PaymentMode @default(SEPA_MONTHLY)
  annualAmount     Float       @default(0)
  monthlyAmount    Float?

  beneficiary Beneficiary @relation("SubscriptionHolder", fields: [beneficiaryId], references: [id])
  referrer    Account?    @relation("SubscriptionReferrer", fields: [referrerId], references: [id])
  payer       Account?    @relation("SubscriptionPayer", fields: [payerId], references: [id])

  payments Payment[]
}

model Payment {
  id             Int      @id @default(autoincrement())
  subscriptionId Int
  amount         Float
  paidAt         DateTime @default(now())
  method         String
  status         String   @default("succeeded")

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@unique([subscriptionId, paidAt, amount])
}
